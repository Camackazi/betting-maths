<div class="cookie-banner" data-cookie-banner hidden role="dialog" aria-label="Cookie notice">
  <div class="cookie-banner-content">
    <div>
      <p class="cookie-title">Cookies and analytics</p>
      <p class="cookie-text">
        Betting Maths uses Google Analytics to understand how visitors use the site. You can accept analytics cookies or reject non-essential cookies.
      </p>
      <p class="cookie-small">
        You can change your choice later using the Cookie settings button. Read the <a href="/cookie-policy/">Cookie Policy</a>.
      </p>
    </div>

    <div class="cookie-actions">
      <button class="cookie-button secondary" type="button" data-cookie-reject>
        Reject non-essential
      </button>
      <button class="cookie-button primary" type="button" data-cookie-accept>
        Accept analytics
      </button>
    </div>
  </div>
</div>

<button class="cookie-settings-button" type="button" data-cookie-settings hidden>
  Cookie settings
</button>

<script is:inline>
  const CONSENT_KEY = "bettingMathsCookieConsent";
  const ANALYTICS_ID = "G-FFL84ZKLKK";

  const banner = document.querySelector("[data-cookie-banner]");
  const acceptButton = document.querySelector("[data-cookie-accept]");
  const rejectButton = document.querySelector("[data-cookie-reject]");
  const settingsButton = document.querySelector("[data-cookie-settings]");

  function getConsentChoice() {
    try {
      return localStorage.getItem(CONSENT_KEY);
    } catch {
      return null;
    }
  }

  function saveConsentChoice(choice) {
    try {
      localStorage.setItem(CONSENT_KEY, choice);
    } catch {
      // If localStorage is unavailable, still respect the user's choice for this page view.
    }
  }

  function deleteCookie(name) {
    const hostname = window.location.hostname;
    const rootDomainParts = hostname.split(".").slice(-2);
    const rootDomain = rootDomainParts.length === 2 ? rootDomainParts.join(".") : hostname;

    document.cookie = `${name}=; Max-Age=0; path=/`;
    document.cookie = `${name}=; Max-Age=0; path=/; domain=${hostname}`;
    document.cookie = `${name}=; Max-Age=0; path=/; domain=.${rootDomain}`;
  }

  function clearAnalyticsCookies() {
    document.cookie
      .split(";")
      .map((cookie) => cookie.split("=")[0].trim())
      .filter((name) =>
        name === "_ga" ||
        name === "_gid" ||
        name === "_gat" ||
        name.startsWith("_ga_") ||
        name.startsWith("_gat_")
      )
      .forEach(deleteCookie);
  }

  function loadAnalytics() {
    if (window.__bettingMathsAnalyticsLoaded) return;

    window.__bettingMathsAnalyticsLoaded = true;
    window.dataLayer = window.dataLayer || [];

    window.gtag = window.gtag || function gtag() {
      window.dataLayer.push(arguments);
    };

    const analyticsScript = document.createElement("script");
    analyticsScript.async = true;
    analyticsScript.src = `https://www.googletagmanager.com/gtag/js?id=${ANALYTICS_ID}`;

    analyticsScript.addEventListener("load", () => {
      window.gtag("js", new Date());
      window.gtag("config", ANALYTICS_ID);
    });

    document.head.appendChild(analyticsScript);
  }

  function hideBanner() {
    if (banner) banner.hidden = true;
  }

  function showBanner() {
    if (banner) banner.hidden = false;
  }

  function showSettingsButton() {
    if (settingsButton) settingsButton.hidden = false;
  }

  function applySavedConsent() {
    const choice = getConsentChoice();

    if (choice === "accepted") {
      loadAnalytics();
      hideBanner();
      showSettingsButton();
      return;
    }

    if (choice === "rejected") {
      clearAnalyticsCookies();
      hideBanner();
      showSettingsButton();
      return;
    }

    showBanner();
  }

  acceptButton?.addEventListener("click", () => {
    saveConsentChoice("accepted");
    loadAnalytics();
    hideBanner();
    showSettingsButton();
  });

  rejectButton?.addEventListener("click", () => {
    saveConsentChoice("rejected");
    clearAnalyticsCookies();
    hideBanner();
    showSettingsButton();
  });

  settingsButton?.addEventListener("click", () => {
    showBanner();
  });

  applySavedConsent();
</script>

<style>
