    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 18px;
    background: #ffffff;
    box-shadow: 0 18px 45px rgba(15, 23, 42, 0.18);
  }

  .cookie-banner-content {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
  }

  .cookie-title {
    margin: 0 0 0.3rem;
    color: var(--color-navy);
    font-weight: 900;
  }

  .cookie-text {
    margin: 0;
