---
interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const siteName = "Betting Maths";
const siteUrl = "https://www.bettingmaths.co.uk";

const pathname = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : `${Astro.url.pathname}/`;

const canonicalUrl = new URL(pathname, siteUrl).toString();

const pageTitle = title.includes(siteName) ? title : `${title} | ${siteName}`;

const isHomePage = pathname === "/";
const isGuidePage = pathname.startsWith("/guides/") && pathname !== "/guides/";
const isCalculatorPage = pathname.startsWith("/calculators/") && pathname !== "/calculators/";

function titleFromSlug(slug: string) {
  return slug
    .split("-")
    .filter(Boolean)
    .map((word) => {
      const smallWords = ["a", "an", "and", "are", "in", "is", "of", "the", "to", "vs"];
      if (smallWords.includes(word)) return word;
      if (word === "uk") return "UK";
      return word.charAt(0).toUpperCase() + word.slice(1);
    })
    .join(" ")
    .replace("Vs", "vs");
}

const pathParts = pathname
  .split("/")
  .filter(Boolean);

const breadcrumbItems = [
  {
    "@type": "ListItem",
    position: 1,
    name: "Home",
    item: siteUrl
  },
  ...pathParts.map((part, index) => {
    const href = `${siteUrl}/${pathParts.slice(0, index + 1).join("/")}/`;

    const nameOverrides: Record<string, string> = {
      calculators: "Calculators",
      guides: "Guides",
      glossary: "Glossary",
      "betting-jargon-explained": "Betting Jargon Explained",
      "privacy-policy": "Privacy Policy",
      "responsible-gambling": "Responsible Gambling"
    };

    return {
      "@type": "ListItem",
      position: index + 2,
      name: nameOverrides[part] ?? titleFromSlug(part),
      item: href
    };
  })
];

const organizationSchema = {
  "@type": "Organization",
  "@id": `${siteUrl}/#organization`,
  name: siteName,
  url: siteUrl
};

const websiteSchema = {
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  name: siteName,
  url: siteUrl,
  description:
    "Free betting calculators and plain-English betting maths guides covering odds, implied probability, overround, bookmaker margin, free bets, matched betting, each-way betting, Rule 4, hedging, dutching and more.",
  publisher: {
    "@id": `${siteUrl}/#organization`
  },
  inLanguage: "en-GB"
};

const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  "@id": `${canonicalUrl}#breadcrumb`,
  itemListElement: breadcrumbItems
};

const webPageSchema = {
  "@type": isHomePage ? "WebSite" : "WebPage",
  "@id": `${canonicalUrl}#webpage`,
  url: canonicalUrl,
  name: pageTitle,
  description,
  isPartOf: {
    "@id": `${siteUrl}/#website`
  },
  breadcrumb: {
    "@id": `${canonicalUrl}#breadcrumb`
  },
  inLanguage: "en-GB"
};

const guideSchema = isGuidePage
  ? {
      "@type": "Article",
      "@id": `${canonicalUrl}#article`,
      headline: title,
      description,
      url: canonicalUrl,
      mainEntityOfPage: {
        "@id": `${canonicalUrl}#webpage`
      },
      publisher: {
        "@id": `${siteUrl}/#organization`
      },
      author: {
        "@id": `${siteUrl}/#organization`
      },
      inLanguage: "en-GB"
    }
  : null;

const calculatorSchema = isCalculatorPage
  ? {
      "@type": "WebApplication",
      "@id": `${canonicalUrl}#calculator`,
      name: title,
      description,
      url: canonicalUrl,
      applicationCategory: "UtilitiesApplication",
      operatingSystem: "Any",
      isAccessibleForFree: true,
      publisher: {
        "@id": `${siteUrl}/#organization`
      },
      inLanguage: "en-GB"
    }
  : null;

const schemaGraph = [
  organizationSchema,
  websiteSchema,
  breadcrumbSchema,
  webPageSchema,
  guideSchema,
  calculatorSchema
].filter(Boolean);

const structuredData = {
  "@context": "https://schema.org",
  "@graph": schemaGraph
};
---

<title>{pageTitle}</title>
<meta name="description" content={description} />

<link rel="canonical" href={canonicalUrl} />

<meta property="og:type" content={isGuidePage ? "article" : "website"} />
<meta property="og:site_name" content={siteName} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:locale" content="en_GB" />

<meta name="twitter:card" content="summary" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />

<meta name="theme-color" content="#1f8a5b" />

<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
