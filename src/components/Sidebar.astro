---
const currentPath = Astro.url.pathname;

const sections = [
  {
    title: "Calculators",
    links: [
      { href: "/calculators/overround-calculator/", label: "Overround Calculator" },
      { href: "/calculators/dutching-calculator/", label: "Dutching Calculator" },
      { href: "/calculators/hedge-bet-calculator/", label: "Hedge Bet Calculator" },
      { href: "/calculators/back-lay-calculator/", label: "Back/Lay Calculator" },
      { href: "/calculators/lay-liability-calculator/", label: "Lay Liability Calculator" },
      { href: "/calculators/odds-converter/", label: "Odds Converter" },
      { href: "/calculators/accumulator-calculator/", label: "Accumulator Calculator" },
      { href: "/calculators/each-way-calculator/", label: "Each-Way Calculator" }
    ]
  },
  {
    title: "Guides",
    links: [
      { href: "/guides/what-is-implied-probability/", label: "What Is Implied Probability?" },
      { href: "/guides/bookmaker-margin-explained/", label: "Bookmaker Margin Explained" },
      { href: "/guides/hedging-vs-cash-out/", label: "Hedging vs Cash Out" },
      { href: "/guides/dutching-vs-arbitrage/", label: "Dutching vs Arbitrage" },
      { href: "/guides/what-is-overround/", label: "What Is Overround?" },
      { href: "/guides/how-to-hedge-a-bet/", label: "How to Hedge a Bet" },
      { href: "/guides/what-is-dutching/", label: "What Is Dutching?" },
      { href: "/guides/how-bookmakers-make-money/", label: "How Bookmakers Make Money" },
      { href: "/guides/can-you-always-beat-the-bookie/", label: "Can You Always Beat the Bookie?" }
    ]
  },
  {
    title: "Glossary",
    links: [
      { href: "/glossary/betting-jargon-explained/", label: "Betting Jargon Explained" }
    ]
  }
];
---

<aside class="sidebar" data-sidebar>
  <nav aria-label="Main navigation">
    <a class={`sidebar-home ${currentPath === "/" ? "active" : ""}`} href="/">Home</a>

    {sections.map((section) => (
      <div class="nav-section">
        <h2>{section.title}</h2>
        <ul>
          {section.links.map((link) => (
            <li>
              <a class={currentPath === link.href ? "active" : ""} href={link.href}>{link.label}</a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>
</aside>
