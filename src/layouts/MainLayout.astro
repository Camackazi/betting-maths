---
import Sidebar from "../components/Sidebar.astro";
import Footer from "../components/Footer.astro";
import SeoHead from "../components/SeoHead.astro";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <SeoHead title={title} description={description} />

    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-FFL84ZKLKK"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag("js", new Date());

      gtag("config", "G-FFL84ZKLKK");
    </script>
  </head>

  <body>
    <div class="site-shell">
      <button class="mobile-menu-button" type="button" data-menu-button aria-label="Open navigation">
        ☰ Menu
      </button>

      <Sidebar />

      <div class="page-shell">
        <main class="main-content">
          <slot />
        </main>

        <Footer />
      </div>
    </div>

    <script is:inline>
      const menuButton = document.querySelector("[data-menu-button]");
      const sidebar = document.querySelector("[data-sidebar]");

      if (menuButton && sidebar) {
        menuButton.addEventListener("click", () => {
          sidebar.classList.toggle("open");
        });

        sidebar.querySelectorAll("a").forEach((link) => {
          link.addEventListener("click", () => {
            sidebar.classList.remove("open");
          });
        });
      }
    </script>

    <style is:global>
      :root {
        --color-bg: #f4f7fa;
        --color-card: #ffffff;
        --color-text: #1c2630;
        --color-muted: #64748b;
        --color-border: #d9e2ec;
        --color-navy: #102a43;
        --color-green: #1f8a5b;
        --color-green-dark: #146c46;
        --color-green-light: #eef8f3;
        --radius: 18px;
        --shadow: 0 18px 45px rgba(15, 23, 42, 0.08);
        --sidebar-width: 292px;
        font-family:
          Inter,
          ui-sans-serif,
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        background:
          radial-gradient(circle at top left, rgba(31, 138, 91, 0.12), transparent 34rem),
          var(--color-bg);
        color: var(--color-text);
        font-size: 16px;
        line-height: 1.65;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        height: auto;
      }

      h1,
      h2,
      h3 {
        color: var(--color-navy);
        line-height: 1.15;
      }

      h1 {
        margin: 0 0 1rem;
        font-size: clamp(2.1rem, 5vw, 4.1rem);
        letter-spacing: -0.055em;
      }

      h2 {
        margin: 0 0 0.8rem;
        font-size: clamp(1.55rem, 3vw, 2.15rem);
        letter-spacing: -0.035em;
      }

      h3 {
        margin: 0 0 0.55rem;
        font-size: 1.12rem;
        letter-spacing: -0.02em;
      }

      p {
        margin: 0 0 1rem;
      }

      ul,
      ol {
        margin-top: 0;
      }

      table {
        font-size: 0.98rem;
      }

      .site-shell {
        display: grid;
        grid-template-columns: var(--sidebar-width) minmax(0, 1fr);
        min-height: 100vh;
      }

      .page-shell {
        min-width: 0;
      }

      .main-content {
        width: min(1180px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 2rem 0 3rem;
      }

      .mobile-menu-button {
        display: none;
      }

      .sidebar {
        position: sticky;
        top: 0;
        height: 100vh;
        overflow-y: auto;
        padding: 1.35rem 1rem 2rem;
        background: #ffffff;
        border-right: 1px solid var(--color-border);
        box-shadow: 12px 0 30px rgba(15, 23, 42, 0.04);
        z-index: 40;
      }

      .sidebar nav {
        display: grid;
        gap: 1rem;
      }

      .sidebar-home {
        display: block;
        padding: 0.85rem 0.95rem;
        border-radius: 14px;
        background: var(--color-green);
        color: #ffffff;
        font-weight: 900;
        box-shadow: 0 12px 28px rgba(31, 138, 91, 0.22);
      }

      .sidebar-home.active {
        background: var(--color-green-dark);
      }

      .nav-section {
        padding-top: 0.5rem;
      }

      .nav-section h2 {
        margin: 0 0 0.55rem;
        padding: 0 0.55rem;
        color: var(--color-muted);
        font-size: 0.78rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .nav-section ul {
        display: grid;
        gap: 0.25rem;
        margin: 0;
        padding: 0;
        list-style: none;
      }

      .nav-section a {
        display: block;
        padding: 0.62rem 0.75rem;
        border-radius: 12px;
        color: var(--color-text);
        font-size: 0.94rem;
        font-weight: 750;
      }

      .nav-section a:hover,
      .nav-section a.active {
        background: var(--color-green-light);
        color: var(--color-green-dark);
      }

      .hero,
      .content-card {
        border: 1px solid var(--color-border);
        border-radius: var(--radius);
        background: rgba(255, 255, 255, 0.94);
        box-shadow: var(--shadow);
      }

      .hero {
        padding: clamp(1.5rem, 4vw, 3rem);
      }

      .content-card {
        padding: clamp(1.25rem, 3vw, 2rem);
        margin-bottom: 1.25rem;
      }

      .eyebrow {
        margin: 0 0 0.8rem;
        color: var(--color-green-dark);
        font-size: 0.82rem;
        font-weight: 900;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .lead {
        max-width: 78ch;
        color: var(--color-muted);
        font-size: clamp(1.05rem, 2vw, 1.22rem);
      }

      .button-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.75rem;
        margin-top: 1.3rem;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.45rem;
        border-radius: 999px;
        padding: 0.8rem 1.05rem;
        border: 1px solid transparent;
        font-weight: 900;
        line-height: 1.2;
        transition:
          transform 160ms ease,
          border-color 160ms ease,
          background 160ms ease,
          color 160ms ease,
          box-shadow 160ms ease;
      }

      .button:hover {
        transform: translateY(-1px);
      }

      .button.primary {
        background: var(--color-green);
        color: #ffffff;
        box-shadow: 0 14px 26px rgba(31, 138, 91, 0.2);
      }

      .button.primary:hover {
        background: var(--color-green-dark);
      }

      .button.secondary {
        background: #ffffff;
        color: var(--color-green-dark);
        border-color: rgba(31, 138, 91, 0.28);
      }

      .button.secondary:hover {
        border-color: rgba(31, 138, 91, 0.55);
        background: var(--color-green-light);
      }

      .grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1rem;
        margin: 1rem 0 1.25rem;
      }

      .callout {
        margin: 1.25rem 0;
        padding: 1rem 1.1rem;
        border: 1px solid rgba(31, 138, 91, 0.22);
        border-left: 5px solid var(--color-green);
        border-radius: 14px;
        background: var(--color-green-light);
        color: var(--color-green-dark);
      }

      .callout p:last-child {
        margin-bottom: 0;
      }

      .callout strong {
        color: var(--color-green-dark);
      }

      .calculator-card {
        display: block;
        padding: 1.2rem;
        border: 1px solid var(--color-border);
        border-radius: 16px;
        background: #ffffff;
        box-shadow: 0 12px 32px rgba(15, 23, 42, 0.05);
        transition:
          transform 160ms ease,
          border-color 160ms ease,
          box-shadow 160ms ease;
      }

      .calculator-card:hover {
        transform: translateY(-2px);
        border-color: rgba(31, 138, 91, 0.45);
        box-shadow: 0 16px 36px rgba(15, 23, 42, 0.08);
      }

      .calculator-card p {
        margin: 0;
        color: var(--color-muted);
      }

      .ad-placeholder {
        display: none;
      }

      .site-footer {
        width: min(1180px, calc(100% - 2rem));
        margin: 0 auto;
        padding: 1.5rem 0 2.5rem;
        color: var(--color-muted);
        font-size: 0.92rem;
      }

      .site-footer a {
        color: var(--color-green-dark);
        font-weight: 800;
        text-decoration: underline;
        text-underline-offset: 3px;
      }

      .footer-inner {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        border-top: 1px solid var(--color-border);
        padding-top: 1.25rem;
      }

      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
      }

      @media (max-width: 1100px) {
        .grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (max-width: 860px) {
        .site-shell {
          display: block;
        }

        .mobile-menu-button {
          display: inline-flex;
          position: sticky;
          top: 0.75rem;
          left: 0.75rem;
          z-index: 60;
          margin: 0.75rem;
          border: 1px solid var(--color-border);
          border-radius: 999px;
          padding: 0.65rem 0.95rem;
          background: #ffffff;
          color: var(--color-navy);
          font: inherit;
          font-weight: 900;
          box-shadow: 0 12px 24px rgba(15, 23, 42, 0.12);
          cursor: pointer;
        }

        .sidebar {
          position: fixed;
          inset: 0 auto 0 0;
          width: min(88vw, 320px);
          transform: translateX(-104%);
          transition: transform 180ms ease;
        }

        .sidebar.open {
          transform: translateX(0);
        }

        .main-content {
          padding-top: 0.5rem;
        }
      }

      @media (max-width: 680px) {
        .grid {
          grid-template-columns: 1fr;
        }

        .main-content {
          width: min(100% - 1rem, 1180px);
        }

        .hero,
        .content-card {
          border-radius: 15px;
        }

        .button {
          width: 100%;
        }

        .footer-inner {
          display: grid;
        }
      }
    </style>
  </body>
</html>
