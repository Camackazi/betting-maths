---
import MainLayout from "../../layouts/MainLayout.astro";
import CalculatorCard from "../../components/CalculatorCard.astro";
---

<MainLayout
  title="Free Betting Calculators"
  description="Free betting calculators for odds, overround, dutching, hedging, back lay betting, lay liability, accumulators and each-way bets."
>
  <section class="content-card">
    <p class="eyebrow">Betting calculators</p>
    <h1>Free Betting Calculators</h1>
    <p class="lead">
      Use these free betting calculators to work out odds, implied probability, overround, dutching stakes, hedge bets, back/lay positions, lay liability, accumulators and each-way returns.
    </p>

    <div class="callout">
      <strong>Quick guide:</strong> Start with the Odds Converter if you want to understand a price, the Overround Calculator if you want to check bookmaker margin, or the relevant staking calculator if you already know the type of bet.
    </div>
  </section>

  <section class="content-card article-section">
    <h2>Most useful betting calculators</h2>
    <p>
      These are the core Betting Maths calculators. They are designed to explain the numbers behind betting, not to provide betting tips or predictions.
    </p>

    <div class="grid calculator-grid">
      <CalculatorCard
        title="Odds Converter"
        description="Convert decimal, fractional and American odds, and calculate implied probability."
        href="/calculators/odds-converter/"
      />

      <CalculatorCard
        title="Overround Calculator"
        description="Calculate book percentage, overround and bookmaker margin in a betting market."
        href="/calculators/overround-calculator/"
      />

      <CalculatorCard
        title="Accumulator Calculator"
        description="Multiply odds across multiple selections and calculate acca returns, profit and implied probability."
        href="/calculators/accumulator-calculator/"
      />

      <CalculatorCard
        title="Each-Way Calculator"
        description="Calculate total stake, place odds, win profit, place-only result and losing outcome."
        href="/calculators/each-way-calculator/"
      />

      <CalculatorCard
        title="Dutching Calculator"
        description="Split a total stake across two or more selections for a balanced return."
        href="/calculators/dutching-calculator/"
      />

      <CalculatorCard
        title="Hedge Bet Calculator"
        description="Calculate back-first and lay-first hedge stakes, lay liability, commission and profit or loss."
        href="/calculators/hedge-bet-calculator/"
      />

      <CalculatorCard
        title="Back/Lay Calculator"
        description="Calculate lay stake, lay liability and profit across standard back bets and free bet examples."
        href="/calculators/back-lay-calculator/"
      />

      <CalculatorCard
        title="Lay Liability Calculator"
        description="Calculate lay liability, exchange commission and profit or loss from a lay bet."
        href="/calculators/lay-liability-calculator/"
      />
    </div>
  </section>

  <section class="content-card article-section">
    <h2>Which betting calculator do I need?</h2>
    <p>
      If you are not sure which calculator to use, this table gives a quick guide.
    </p>

    <table class="example-table">
      <thead>
        <tr>
          <th>What you want to calculate</th>
          <th>Best calculator</th>
          <th>What it shows</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Convert odds or calculate implied probability</td>
          <td><a href="/calculators/odds-converter/">Odds Converter</a></td>
          <td>Decimal, fractional, American odds and implied chance.</td>
        </tr>
        <tr>
          <td>Check bookmaker margin in a market</td>
          <td><a href="/calculators/overround-calculator/">Overround Calculator</a></td>
          <td>Book percentage, overround and market margin.</td>
        </tr>
        <tr>
          <td>Work out accumulator returns</td>
          <td><a href="/calculators/accumulator-calculator/">Accumulator Calculator</a></td>
          <td>Combined odds, return, profit and implied probability.</td>
        </tr>
        <tr>
          <td>Calculate each-way returns</td>
          <td><a href="/calculators/each-way-calculator/">Each-Way Calculator</a></td>
          <td>Total stake, place odds, win result, place-only result and loss.</td>
        </tr>
        <tr>
          <td>Split stakes across multiple selections</td>
          <td><a href="/calculators/dutching-calculator/">Dutching Calculator</a></td>
          <td>Stake per selection, return and equalised profit or loss.</td>
        </tr>
        <tr>
          <td>Hedge an existing betting position</td>
          <td><a href="/calculators/hedge-bet-calculator/">Hedge Bet Calculator</a></td>
          <td>Back-first or lay-first hedge stakes and outcomes.</td>
        </tr>
        <tr>
          <td>Back first, then lay on an exchange</td>
          <td><a href="/calculators/back-lay-calculator/">Back/Lay Calculator</a></td>
          <td>Lay stake, lay liability, commission and balanced result.</td>
        </tr>
        <tr>
          <td>Understand the risk on a lay bet</td>
          <td><a href="/calculators/lay-liability-calculator/">Lay Liability Calculator</a></td>
          <td>Lay liability, gross win, commission and result if the selection wins or loses.</td>
        </tr>
      </tbody>
    </table>
  </section>

  <section class="content-card article-section">
    <h2>Odds and market margin calculators</h2>
    <p>
      These calculators help explain the price of a bet and the margin built into a market.
    </p>

    <div class="related-grid">
      <a class="related-card" href="/calculators/odds-converter/">
        <h3>Odds Converter</h3>
        <p>Convert decimal, fractional and American odds into implied probability.</p>
      </a>

      <a class="related-card" href="/calculators/overround-calculator/">
        <h3>Overround Calculator</h3>
        <p>Check book percentage, overround, underround and bookmaker margin.</p>
      </a>
    </div>
  </section>

  <section class="content-card article-section">
    <h2>Staking and returns calculators</h2>
    <p>
      These calculators help work out possible returns from common bet types.
    </p>

    <div class="related-grid">
      <a class="related-card" href="/calculators/accumulator-calculator/">
        <h3>Accumulator Calculator</h3>
        <p>Calculate acca odds, returns, profit and implied probability.</p>
      </a>

      <a class="related-card" href="/calculators/each-way-calculator/">
        <h3>Each-Way Calculator</h3>
        <p>Calculate win, place-only and losing outcomes for each-way bets.</p>
      </a>

      <a class="related-card" href="/calculators/dutching-calculator/">
        <h3>Dutching Calculator</h3>
        <p>Split a stake across two or more selections for balanced returns.</p>
      </a>
    </div>
  </section>

  <section class="content-card article-section">
    <h2>Exchange and hedging calculators</h2>
    <p>
      These calculators help with back bets, lay bets, liability, commission and hedging.
    </p>

    <div class="related-grid">
      <a class="related-card" href="/calculators/hedge-bet-calculator/">
        <h3>Hedge Bet Calculator</h3>
        <p>Calculate hedge stakes for back-first and lay-first betting positions.</p>
      </a>

      <a class="related-card" href="/calculators/back-lay-calculator/">
        <h3>Back/Lay Calculator</h3>
        <p>Calculate lay stake, liability and profit across back and lay outcomes.</p>
      </a>

      <a class="related-card" href="/calculators/lay-liability-calculator/">
        <h3>Lay Liability Calculator</h3>
        <p>Understand the real exposure created by a lay bet.</p>
      </a>
    </div>
  </section>

  <section class="content-card article-section">
    <h2>Learn the betting maths behind the calculators</h2>
    <p>
      If you want to understand the calculations before using the tools, these guides are a good place to start.
    </p>

    <div class="related-grid">
      <a class="related-card" href="/guides/what-is-implied-probability/">
        <h3>What Is Implied Probability?</h3>
        <p>Learn how odds convert into percentage chance.</p>
      </a>

      <a class="related-card" href="/guides/bookmaker-margin-explained/">
        <h3>Bookmaker Margin Explained</h3>
        <p>Understand bookmaker margin, overround and book percentage.</p>
      </a>

      <a class="related-card" href="/guides/how-to-hedge-a-bet/">
        <h3>How to Hedge a Bet</h3>
        <p>Learn how back and lay hedging works.</p>
      </a>

      <a class="related-card" href="/glossary/betting-jargon-explained/">
        <h3>Betting Jargon Explained</h3>
        <p>Look up common betting terms in plain English.</p>
      </a>
    </div>
  </section>

  <div class="callout">
    <strong>Responsible note:</strong> These calculators are for educational and calculation purposes only. They do not predict results, provide betting tips or guarantee profit.
  </div>

  <style>
    .article-section {
      margin-top: 1.25rem;
    }

    .calculator-grid {
      margin-top: 1rem;
    }

    .example-table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      border: 1px solid var(--color-border);
      border-radius: 14px;
      overflow: hidden;
      margin: 1rem 0;
    }

    .example-table th,
    .example-table td {
      padding: 0.75rem;
      border-bottom: 1px solid var(--color-border);
      text-align: left;
      vertical-align: middle;
    }

    .example-table th {
      color: var(--color-navy);
      background: #f4f7fa;
      font-size: 0.9rem;
    }

    .example-table tr:last-child td {
      border-bottom: 0;
    }

    .example-table a {
      color: var(--color-green-dark);
      font-weight: 800;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .related-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 1rem;
    }

    .related-card {
      display: block;
      padding: 1rem;
      border: 1px solid var(--color-border);
      border-radius: 14px;
      background: var(--color-bg);
    }

    .related-card:hover {
      border-color: rgba(31, 138, 91, 0.45);
      transform: translateY(-2px);
    }

    .related-card h3 {
      margin-bottom: 0.35rem;
    }

    .related-card p {
      margin: 0;
      color: var(--color-muted);
    }

    @media (max-width: 980px) {
      .related-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 760px) {
      .related-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</MainLayout>
