  <div class="callout">
    <strong>Responsible note:</strong> These guides are for education only. They do not provide betting tips, predictions or guaranteed profit strategies. Betting always involves risk.
  </div>

  <style>
    .article-section {
      margin-top: 1.25rem;
    }

    .guide-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 1rem;
    }

    .guide-card {
      display: block;
      padding: 1.15rem;
      border: 1px solid var(--color-border);
      border-radius: 14px;
      background: var(--color-bg);
    }

    .guide-card:hover {
      border-color: rgba(31, 138, 91, 0.45);
      transform: translateY(-2px);
    }

    .guide-card span {
      display: inline-flex;
      margin-bottom: 0.5rem;
      padding: 0.15rem 0.55rem;
      border-radius: 999px;
      background: #eef8f3;
      color: var(--color-green-dark);
      font-size: 0.78rem;
      font-weight: 800;
    }

    .guide-card.featured-guide {
      background: #eef8f3;
      border-color: rgba(31, 138, 91, 0.28);
    }

    .guide-card.featured-guide span {
      background: white;
    }

    .guide-card h3 {
      margin-bottom: 0.35rem;
    }

    .guide-card p {
      margin: 0;
      color: var(--color-muted);
    }

    .example-table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      border: 1px solid var(--color-border);
      border-radius: 14px;
      overflow: hidden;
      margin: 1rem 0;
    }

    .example-table th,
    .example-table td {
      padding: 0.75rem;
      border-bottom: 1px solid var(--color-border);
      text-align: left;
      vertical-align: middle;
    }

    .example-table th {
      color: var(--color-navy);
      background: #f4f7fa;
      font-size: 0.9rem;
    }

    .example-table tr:last-child td {
      border-bottom: 0;
    }

    .example-table a {
      color: var(--color-green-dark);
      font-weight: 800;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .topic-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 1rem;
    }

    .topic-card {
      padding: 1rem;
      border: 1px solid var(--color-border);
      border-radius: 14px;
      background: var(--color-bg);
    }

    .topic-card h3 {
      margin-bottom: 0.65rem;
    }

    .topic-card ul {
      margin: 0;
      padding-left: 1.2rem;
    }

    .topic-card li {
      margin: 0.35rem 0;
    }

    .topic-card a {
      color: var(--color-green-dark);
      font-weight: 800;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    @media (max-width: 1100px) {
      .guide-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 760px) {
      .guide-grid,
      .topic-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</MainLayout>
