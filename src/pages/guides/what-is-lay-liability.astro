      margin-top: 1.25rem;
    }

    .formula-box {
      padding: 1rem 1.15rem;
      border-radius: 14px;
      background: var(--color-bg);
      border: 1px solid var(--color-border);
    }

    .formula-box p {
      margin: 0.4rem 0;
      font-weight: 700;
    }

    .standard-list {
      padding-left: 1.3rem;
    }

    .standard-list li {
      margin: 0.45rem 0;
    }

    .example-table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      border: 1px solid var(--color-border);
      border-radius: 14px;
      overflow: hidden;
      margin: 1rem 0;
    }

    .example-table th,
    .example-table td {
      padding: 0.75rem;
      border-bottom: 1px solid var(--color-border);
      text-align: left;
      vertical-align: middle;
    }

    .example-table th {
      color: var(--color-navy);
      background: #f4f7fa;
      font-size: 0.9rem;
    }

    .example-table tr:last-child td {
      border-bottom: 0;
    }

    .related-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 1rem;
    }

    .related-card {
      display: block;
      padding: 1rem;
      border: 1px solid var(--color-border);
      border-radius: 14px;
      background: var(--color-bg);
    }

    .related-card:hover {
      border-color: rgba(31, 138, 91, 0.45);
      transform: translateY(-2px);
    }

    .related-card p {
      margin: 0;
      color: var(--color-muted);
    }

    .article-section a,
    .callout a {
      color: var(--color-green-dark);
      font-weight: 800;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    @media (max-width: 980px) {
      .related-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 760px) {
      .related-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</MainLayout>
