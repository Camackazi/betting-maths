      width: 100%;
      border-collapse: collapse;
      background: white;
      border: 1px solid var(--color-border);
      border-radius: 14px;
      overflow: hidden;
      margin: 1rem 0;
    }

    .example-table th,
    .example-table td {
      padding: 0.75rem;
      border-bottom: 1px solid var(--color-border);
