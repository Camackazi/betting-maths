    .example-table th,
    .example-table td {
      padding: 0.75rem;
      border-bottom: 1px solid var(--color-border);
      text-align: left;
      vertical-align: middle;
    }

    .example-table th {
      color: var(--color-navy);
      background: #f4f7fa;
      font-size: 0.9rem;
    }

    .example-table tr:last-child td {
      border-bottom: 0;
    }

    .related-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 1rem;
    }

    .related-card {
      display: block;
      padding: 1rem;
      border: 1px solid var(--color-border);
      border-radius: 14px;
      background: var(--color-bg);
    }

