---
import MainLayout from "../layouts/MainLayout.astro";
import CalculatorCard from "../components/CalculatorCard.astro";
---

<MainLayout
  title="Free Betting Calculators and Betting Maths Guides"
  description="Free betting calculators and plain-English guides to help you understand odds, overround, dutching, hedging, back lay betting, accumulators, each-way bets, lay liability, bookmaker margin and betting jargon."
>
  <section class="hero">
    <p class="eyebrow">Betting calculators and plain-English guides</p>
    <h1>Understand the odds. Use the maths. Bet smarter.</h1>
    <p class="lead">
      Betting Maths helps you understand odds, stakes, overround, dutching, hedging, back/lay betting, accumulators, each-way bets, lay liability, bookmaker margin and common betting jargon with simple calculators and practical examples.
    </p>
    <div class="button-row">
      <a class="button primary" href="/calculators/overround-calculator/">Start with the Overround Calculator</a>
      <a class="button secondary" href="/glossary/betting-jargon-explained/">Explore the Betting Glossary</a>
    </div>
  </section>

  <section class="content-card intro-panel">
    <h2>What is Betting Maths?</h2>
    <p>
      Betting Maths is a free betting education and calculator site. It is designed to explain how odds, implied probability, overround, dutching, hedging, back/lay betting, accumulators, each-way bets, lay liability and bookmaker margins work in plain English.
    </p>
    <p>
      The aim is not to provide betting tips or guaranteed profit systems. The aim is to help you understand the numbers behind betting markets so you can read odds, calculate outcomes and understand risk more clearly.
    </p>
  </section>

  <h2>Popular betting calculators</h2>
  <div class="grid calculator-grid">
    <CalculatorCard
      title="Overround Calculator"
      description="Work out the total book percentage and bookmaker margin built into a betting market."
      href="/calculators/overround-calculator/"
    />
    <CalculatorCard
      title="Odds Converter"
      description="Convert decimal, fractional and American odds, and calculate implied probability."
      href="/calculators/odds-converter/"
    />
    <CalculatorCard
      title="Dutching Calculator"
      description="Split a total stake across two or more selections for a balanced return."
      href="/calculators/dutching-calculator/"
    />
    <CalculatorCard
      title="Hedge Bet Calculator"
      description="Calculate back-first and lay-first hedge stakes, lay liability, commission and possible profit or loss."
      href="/calculators/hedge-bet-calculator/"
    />
    <CalculatorCard
      title="Back/Lay Calculator"
      description="Calculate lay stake, lay liability and profit across standard back bets and free bet examples."
      href="/calculators/back-lay-calculator/"
    />
    <CalculatorCard
      title="Lay Liability Calculator"
      description="Calculate lay liability, exchange commission and profit or loss from a lay bet."
      href="/calculators/lay-liability-calculator/"
    />
    <CalculatorCard
      title="Accumulator Calculator"
      description="Multiply odds across multiple selections and calculate acca returns, profit and implied probability."
      href="/calculators/accumulator-calculator/"
    />
    <CalculatorCard
      title="Each-Way Calculator"
      description="Calculate total stake, place odds, win return, place return and each-way profit or loss."
      href="/calculators/each-way-calculator/"
    />
  </div>

  <section class="content-card article-section">
    <h2>Learn the key betting maths concepts</h2>
    <p>
      Start with these guides if you want to understand how odds are priced, how bookmaker margin works, how staking methods differ, and why betting systems should be treated carefully.
    </p>

    <div class="guide-grid">
      <a class="guide-card featured-guide" href="/guides/what-is-implied-probability/">
        <span>Core guide</span>
        <h3>What Is Implied Probability?</h3>
        <p>Learn how odds convert into percentage chance and why implied probability matters across betting maths.</p>
      </a>

      <a class="guide-card featured-guide" href="/guides/bookmaker-margin-explained/">
        <span>Core guide</span>
        <h3>Bookmaker Margin Explained</h3>
        <p>Understand bookmaker margin, overround, book percentage and why markets usually add up to more than 100%.</p>
      </a>

      <a class="guide-card" href="/guides/what-is-overround/">
        <span>Guide</span>
        <h3>What Is Overround in Betting?</h3>
        <p>Learn how book percentage and bookmaker margin are calculated from market odds.</p>
      </a>

      <a class="guide-card" href="/guides/how-bookmakers-make-money/">
        <span>Guide</span>
        <h3>How Bookmakers Make Money</h3>
        <p>Understand overround, odds movement, weight of money and liability management.</p>
      </a>

      <a class="guide-card" href="/guides/how-to-hedge-a-bet/">
        <span>Guide</span>
        <h3>How to Hedge a Bet</h3>
        <p>Understand back and lay hedging, lay liability, commission and greening up.</p>
      </a>

      <a class="guide-card" href="/guides/hedging-vs-cash-out/">
        <span>Guide</span>
        <h3>Hedging vs Cash Out</h3>
        <p>Compare bookmaker cash out offers with manual hedging calculations.</p>
      </a>

      <a class="guide-card" href="/guides/what-is-dutching/">
        <span>Guide</span>
        <h3>What Is Dutching in Betting?</h3>
        <p>Learn how dutching splits stakes across multiple selections.</p>
      </a>

      <a class="guide-card" href="/guides/dutching-vs-arbitrage/">
        <span>Guide</span>
        <h3>Dutching vs Arbitrage</h3>
        <p>Learn the difference between splitting stakes and covering all outcomes for a theoretical profit.</p>
      </a>

      <a class="guide-card" href="/guides/can-you-always-beat-the-bookie/">
        <span>Guide</span>
        <h3>Can You Always Beat the Bookie?</h3>
        <p>Learn why guaranteed betting systems are risky and what maths can actually show.</p>
      </a>
    </div>
  </section>

  <section class="content-card article-section">
    <h2>Betting jargon explained</h2>
    <p>
      Betting can be full of confusing terms: acca, overround, lay bet, liability, vig, juice, dutching, hedging, back/lay, each-way, value betting, underround and more.
    </p>
    <p>
      Our betting glossary explains common betting terms in plain English and links important maths terms to the right calculator.
    </p>

    <div class="button-row">
      <a class="button primary" href="/glossary/betting-jargon-explained/">Open the Betting Jargon Glossary</a>
    </div>
  </section>

  <section class="content-card article-section">
    <h2>Start with a simple bookmaker margin example</h2>
    <p>
      A football match might have odds of 2.10 for the home win, 3.40 for the draw and 3.60 for the away win. Converted into implied probability, those prices add up to 104.81%.
    </p>

    <table class="example-table">
      <thead>
        <tr>
          <th>Outcome</th>
          <th>Decimal odds</th>
          <th>Implied probability</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Home win</td>
          <td>2.10</td>
          <td>47.62%</td>
        </tr>
        <tr>
          <td>Draw</td>
          <td>3.40</td>
          <td>29.41%</td>
        </tr>
        <tr>
          <td>Away win</td>
          <td>3.60</td>
          <td>27.78%</td>
        </tr>
      </tbody>
    </table>

    <p>
      That means the market has a 4.81% overround. This is one simple example of how betting maths helps explain bookmaker margin.
    </p>
  </section>

  <section class="content-card article-section">
    <h2>Back/lay example</h2>
    <p>
      A back/lay calculation is useful when you back a selection first and then lay the same selection on an exchange. For example, backing £100 at 3.00 and laying at 2.00 with 2% commission creates a balanced hedge.
    </p>

    <table class="example-table">
      <thead>
        <tr>
          <th>Back stake</th>
          <th>Back odds</th>
          <th>Lay odds</th>
          <th>Commission</th>
          <th>Lay stake</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>£100</td>
          <td>3.00</td>
          <td>2.00</td>
          <td>2%</td>
          <td>£151.52</td>
        </tr>
      </tbody>
    </table>

    <p>
      The <a href="/calculators/back-lay-calculator/">Back/Lay Calculator</a> works out the lay stake, lay liability and profit if the selection wins or loses. For lay-first positions, use the <a href="/calculators/hedge-bet-calculator/">Hedge Bet Calculator</a>.
    </p>
  </section>

  <section class="content-card article-section">
    <h2>Accumulator example</h2>
    <p>
      Accumulators multiply odds together. For example, decimal odds of 2.00, 1.80 and 2.50 combine to make accumulator odds of 9.00.
    </p>

    <table class="example-table">
      <thead>
        <tr>
          <th>Selection</th>
          <th>Decimal odds</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Selection 1</td>
          <td>2.00</td>
        </tr>
        <tr>
          <td>Selection 2</td>
          <td>1.80</td>
        </tr>
        <tr>
          <td>Selection 3</td>
          <td>2.50</td>
        </tr>
      </tbody>
    </table>

    <p>
      A £10 stake at combined odds of 9.00 would return £90, including £80 profit. The <a href="/calculators/accumulator-calculator/">Accumulator Calculator</a> works this out automatically and also shows the implied probability.
    </p>
  </section>

  <section class="content-card article-section">
    <h2>Back, lay and liability example</h2>
    <p>
      Lay betting is different from normal backing because your risk is based on liability. If you lay £100 at odds of 3.00, your liability is £200.
    </p>

    <table class="example-table">
      <thead>
        <tr>
          <th>Lay stake</th>
          <th>Lay odds</th>
          <th>Liability</th>
          <th>If selection loses</th>
          <th>If selection wins</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>£100</td>
          <td>3.00</td>
          <td>£200</td>
          <td>Lay bet wins</td>
          <td>Lay bet loses</td>
        </tr>
      </tbody>
    </table>

    <p>
      The <a href="/calculators/lay-liability-calculator/">Lay Liability Calculator</a> helps show the real exposure behind a lay bet.
    </p>
  </section>

  <section class="content-card article-section">
    <h2>Each-way example</h2>
    <p>
      A £10 each-way bet usually costs £20 in total because it is really two bets: £10 on the win part and £10 on the place part.
    </p>

    <table class="example-table">
      <thead>
        <tr>
          <th>Stake</th>
          <th>Win odds</th>
          <th>Place terms</th>
          <th>Total stake</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>£10 each-way</td>
          <td>9.00</td>
          <td>1/5 odds</td>
          <td>£20</td>
        </tr>
      </tbody>
    </table>

    <p>
      The <a href="/calculators/each-way-calculator/">Each-Way Calculator</a> works out the total stake, place odds, win profit, place-only result and losing result.
    </p>
  </section>

  <div class="callout">
    <strong>Responsible note:</strong> Betting Maths is an educational calculator site. It does not provide betting tips, financial advice or guaranteed profit strategies. Betting always involves risk.
  </div>

  <style>
    .intro-panel {
      margin-top: 1.25rem;
    }

    .article-section {
      margin-top: 1.25rem;
    }

    .guide-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 1rem;
    }

    .guide-card {
      display: block;
      padding: 1.15rem;
      border: 1px solid var(--color-border);
      border-radius: 14px;
      background: var(--color-bg);
    }

    .guide-card:hover {
      border-color: rgba(31, 138, 91, 0.45);
      transform: translateY(-2px);
    }

    .guide-card span {
      display: inline-flex;
      margin-bottom: 0.5rem;
      padding: 0.15rem 0.55rem;
      border-radius: 999px;
      background: #eef8f3;
      color: var(--color-green-dark);
      font-size: 0.78rem;
      font-weight: 800;
    }

    .guide-card.featured-guide {
      background: #eef8f3;
      border-color: rgba(31, 138, 91, 0.28);
    }

    .guide-card.featured-guide span {
      background: white;
    }

    .guide-card h3 {
      margin-bottom: 0.35rem;
    }

    .guide-card p {
      margin: 0;
      color: var(--color-muted);
    }

    .example-table {
      width: 100%;
      border-collapse: collapse;
      background: white;
      border: 1px solid var(--color-border);
      border-radius: 14px;
      overflow: hidden;
      margin: 1rem 0;
    }

    .example-table th,
    .example-table td {
      padding: 0.75rem;
      border-bottom: 1px solid var(--color-border);
      text-align: left;
      vertical-align: middle;
    }

    .example-table th {
      color: var(--color-navy);
      background: #f4f7fa;
      font-size: 0.9rem;
    }

    .example-table tr:last-child td {
      border-bottom: 0;
    }

    .article-section a {
      color: var(--color-green-dark);
      font-weight: 800;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    @media (max-width: 1100px) {
      .guide-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 760px) {
      .guide-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</MainLayout>
