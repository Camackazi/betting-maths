---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout
  title="Sitemap"
  description="Sitemap for Betting Maths, including all betting calculators, guides, glossary pages and site information pages."
>
  <section class="content-card">
    <p class="eyebrow">Site navigation</p>
    <h1>Sitemap</h1>
    <p class="lead">
      Use this sitemap to find all the main Betting Maths calculators, guides, glossary pages and site information pages.
    </p>

    <div class="callout">
      <strong>Looking for the XML sitemap?</strong> Search engines can use the technical sitemap at <a href="/sitemap-index.xml">sitemap-index.xml</a>.
    </div>
  </section>

  <section class="content-card sitemap-section">
    <h2>Main pages</h2>
    <div class="sitemap-grid">
      <a class="sitemap-card" href="/">
        <span>Home</span>
        <h3>Betting Maths</h3>
        <p>The main homepage for calculators, guides and betting maths explanations.</p>
      </a>

      <a class="sitemap-card" href="/calculators/">
        <span>Hub</span>
        <h3>All Calculators</h3>
        <p>Browse all betting calculators in one place.</p>
      </a>

      <a class="sitemap-card" href="/guides/">
        <span>Hub</span>
        <h3>All Guides</h3>
        <p>Browse all betting maths guides in one place.</p>
      </a>

      <a class="sitemap-card" href="/glossary/betting-jargon-explained/">
        <span>Glossary</span>
        <h3>Betting Jargon Explained</h3>
        <p>A plain-English A-Z glossary of betting terms.</p>
      </a>
    </div>
  </section>

  <section class="content-card sitemap-section">
    <h2>Betting calculators</h2>
    <p>
      These calculators help explain odds, stakes, returns, bookmaker margin, exchange liability, hedging and common betting calculations.
    </p>

    <div class="sitemap-grid">
      <a class="sitemap-card" href="/calculators/odds-converter/">
        <span>Calculator</span>
        <h3>Odds Converter</h3>
        <p>Convert decimal, fractional and American odds, and calculate implied probability.</p>
      </a>

      <a class="sitemap-card" href="/calculators/overround-calculator/">
        <span>Calculator</span>
        <h3>Overround Calculator</h3>
        <p>Calculate book percentage, overround and bookmaker margin.</p>
      </a>

      <a class="sitemap-card" href="/calculators/arbitrage-calculator/">
        <span>Calculator</span>
        <h3>Arbitrage Calculator</h3>
        <p>Check underrounds and calculate arbitrage stake splits.</p>
      </a>

      <a class="sitemap-card" href="/calculators/dutching-calculator/">
        <span>Calculator</span>
        <h3>Dutching Calculator</h3>
        <p>Split a stake across two or more selections for balanced returns.</p>
      </a>

      <a class="sitemap-card" href="/calculators/hedge-bet-calculator/">
        <span>Calculator</span>
        <h3>Hedge Bet Calculator</h3>
        <p>Calculate back-first and lay-first hedge positions.</p>
      </a>

      <a class="sitemap-card" href="/calculators/back-lay-calculator/">
        <span>Calculator</span>
        <h3>Back/Lay Calculator</h3>
        <p>Calculate lay stake, lay liability, commission and balanced outcomes.</p>
      </a>

      <a class="sitemap-card" href="/calculators/free-bet-calculator/">
        <span>Calculator</span>
        <h3>Free Bet Calculator</h3>
        <p>Calculate lay stake, liability, conversion rate and free bet profit.</p>
      </a>

      <a class="sitemap-card" href="/calculators/matched-betting-calculator/">
        <span>Calculator</span>
        <h3>Matched Betting Calculator</h3>
        <p>Estimate qualifying loss, free bet profit and overall matched betting result.</p>
      </a>

      <a class="sitemap-card" href="/calculators/lay-liability-calculator/">
        <span>Calculator</span>
        <h3>Lay Liability Calculator</h3>
        <p>Calculate lay liability, exchange commission and lay bet results.</p>
      </a>

      <a class="sitemap-card" href="/calculators/kelly-criterion-calculator/">
        <span>Calculator</span>
        <h3>Kelly Criterion Calculator</h3>
        <p>Estimate stake size using bankroll, odds and your estimated probability.</p>
      </a>

      <a class="sitemap-card" href="/calculators/accumulator-calculator/">
        <span>Calculator</span>
        <h3>Accumulator Calculator</h3>
        <p>Calculate combined odds, acca returns, profit and implied probability.</p>
      </a>

      <a class="sitemap-card" href="/calculators/each-way-calculator/">
        <span>Calculator</span>
        <h3>Each-Way Calculator</h3>
        <p>Calculate total stake, place odds, win result, place-only result and loss.</p>
      </a>

      <a class="sitemap-card" href="/calculators/each-way-extra-places-calculator/">
        <span>Calculator</span>
        <h3>Each-Way Extra Places Calculator</h3>
        <p>Compare standard place terms with enhanced extra places offers.</p>
      </a>

      <a class="sitemap-card" href="/calculators/rule-4-calculator/">
        <span>Calculator</span>
        <h3>Rule 4 Calculator</h3>
        <p>Estimate horse racing Rule 4 deductions and adjusted returns.</p>
      </a>
    </div>
  </section>

  <section class="content-card sitemap-section">
    <h2>Betting maths guides</h2>
    <p>
      These guides explain the concepts behind the calculators in plain English.
    </p>

    <div class="sitemap-grid">
      <a class="sitemap-card" href="/guides/what-is-implied-probability/">
        <span>Guide</span>
        <h3>What Is Implied Probability?</h3>
        <p>Learn how odds convert into percentage chance.</p>
      </a>

      <a class="sitemap-card" href="/guides/bookmaker-margin-explained/">
        <span>Guide</span>
        <h3>Bookmaker Margin Explained</h3>
        <p>Understand bookmaker margin, overround and book percentage.</p>
      </a>

      <a class="sitemap-card" href="/guides/what-is-overround/">
        <span>Guide</span>
        <h3>What Is Overround?</h3>
        <p>Learn why betting markets usually add up to more than 100%.</p>
      </a>

      <a class="sitemap-card" href="/guides/how-bookmakers-make-money/">
        <span>Guide</span>
        <h3>How Bookmakers Make Money</h3>
        <p>Understand margin, odds movement, weight of money and liability management.</p>
      </a>

      <a class="sitemap-card" href="/guides/can-you-always-beat-the-bookie/">
        <span>Guide</span>
        <h3>Can You Always Beat the Bookie?</h3>
        <p>Learn why guaranteed betting systems are risky.</p>
      </a>

      <a class="sitemap-card" href="/guides/how-to-hedge-a-bet/">
        <span>Guide</span>
        <h3>How to Hedge a Bet</h3>
        <p>Understand back and lay hedging, lay liability and commission.</p>
      </a>

      <a class="sitemap-card" href="/guides/hedging-vs-cash-out/">
        <span>Guide</span>
        <h3>Hedging vs Cash Out</h3>
        <p>Compare bookmaker cash out offers with manual hedging calculations.</p>
      </a>

      <a class="sitemap-card" href="/guides/what-is-dutching/">
        <span>Guide</span>
        <h3>What Is Dutching?</h3>
        <p>Learn how dutching splits stakes across multiple selections.</p>
      </a>

      <a class="sitemap-card" href="/guides/dutching-vs-arbitrage/">
        <span>Guide</span>
        <h3>Dutching vs Arbitrage</h3>
        <p>Understand the difference between dutching and arbitrage betting.</p>
      </a>
    </div>
  </section>

  <section class="content-card sitemap-section">
    <h2>Site information</h2>

    <div class="sitemap-grid">
      <a class="sitemap-card" href="/about/">
        <span>Info</span>
        <h3>About</h3>
        <p>Learn what Betting Maths is and what the site is for.</p>
      </a>

      <a class="sitemap-card" href="/responsible-gambling/">
        <span>Important</span>
        <h3>Responsible Gambling</h3>
        <p>Safer gambling reminders, support information and responsible gambling resources.</p>
      </a>

      <a class="sitemap-card" href="/disclaimer/">
        <span>Legal</span>
        <h3>Disclaimer</h3>
        <p>Important information about educational content, risk and no betting advice.</p>
      </a>

      <a class="sitemap-card" href="/privacy-policy/">
        <span>Legal</span>
        <h3>Privacy Policy</h3>
        <p>Information about privacy, analytics, cookies and future advertising or affiliate links.</p>
      </a>

      <a class="sitemap-card" href="/contact/">
        <span>Info</span>
        <h3>Contact</h3>
        <p>Current contact information and site communication notes.</p>
      </a>
    </div>
  </section>

  <div class="callout">
    <strong>Responsible note:</strong> Betting Maths is an educational site. It does not provide betting tips, predictions, financial advice or guaranteed profit strategies.
  </div>

  <style>
    .sitemap-section {
      margin-top: 1.25rem;
    }

    .sitemap-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1rem;
      margin-top: 1rem;
    }

    .sitemap-card {
      display: block;
      padding: 1.15rem;
      border: 1px solid var(--color-border);
      border-radius: 14px;
      background: var(--color-bg);
    }

    .sitemap-card:hover {
      border-color: rgba(31, 138, 91, 0.45);
      transform: translateY(-2px);
    }

    .sitemap-card span {
      display: inline-flex;
      margin-bottom: 0.5rem;
      padding: 0.15rem 0.55rem;
      border-radius: 999px;
      background: #eef8f3;
      color: var(--color-green-dark);
      font-size: 0.78rem;
      font-weight: 800;
    }

    .sitemap-card h3 {
      margin-bottom: 0.35rem;
    }

    .sitemap-card p {
      margin: 0;
      color: var(--color-muted);
    }

    .callout a {
      color: var(--color-green-dark);
      font-weight: 800;
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    @media (max-width: 1100px) {
      .sitemap-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }

    @media (max-width: 760px) {
      .sitemap-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>
</MainLayout>
